{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/.venv/bin/python3\" \"${CLAUDE_PLUGIN_ROOT}/scripts/init_tracing.py\" \"${CLAUDE_PLUGIN_DATA}\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/.venv/bin/python3\" \"${CLAUDE_PLUGIN_ROOT}/scripts/trace_hook.py\""
          }
        ]
      }
    ]
  }
}
